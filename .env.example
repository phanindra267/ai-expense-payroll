# ===========================================
# AI-Smart Expense & Payroll Management System
# Environment Configuration
# ===========================================

# Application
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb://mongodb:27017/expense-payroll
MONGODB_URI_TEST=mongodb://localhost:27017/expense-payroll-test

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Email (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@expense-payroll.com

# Ollama (AI)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3

# ChromaDB (Optional - falls back to MongoDB text search)
CHROMA_URL=http://chromadb:8000
CHROMA_ENABLED=false

# Slack Webhook (Optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# OpenTelemetry
OTEL_ENABLED=true
OTEL_EXPORTER=console
JAEGER_ENDPOINT=http://jaeger:4318/v1/traces

# Prometheus
PROMETHEUS_ENABLED=true

# Logging
LOG_LEVEL=info

# Password Reset
PASSWORD_RESET_EXPIRY=3600000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
